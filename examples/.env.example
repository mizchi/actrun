# actrun environment file example
# Load with: actrun workflow run ci.yml --env .env

# Secrets (mapped to ${{ secrets.<name> }})
ACTRUN_SECRET_API_TOKEN=your-token-here
ACTRUN_SECRET_DEPLOY_KEY=your-deploy-key

# Variables (mapped to ${{ vars.<name> }})
ACTRUN_VAR_ENVIRONMENT=staging
ACTRUN_VAR_DEBUG=true
